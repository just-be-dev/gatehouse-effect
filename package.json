{
  "name": "gatehouse-effect",
  "module": "src/gatehouse.ts",
  "description": "A TypeScript library for building and managing authorization policies.",
  "author": "Justin Bennett <oss@just-be.dev>",
  "contributors": [
    "gr4vityWall (https://github.com/9Morello)"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/9Morello/gatehouse-ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/9Morello/gatehouse-ts.git"
  },
  "keywords": [
    "authorization",
    "policy",
    "gatehouse",
    "typescript"
  ],
  "version": "1.0.0",
  "type": "module",
  "main": "dist/gatehouse.js",
  "types": "dist/gatehouse.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/gatehouse.d.ts",
      "default": "./dist/gatehouse.js"
    }
  },
  "scripts": {
    "build": "bun build src/gatehouse.ts --outdir dist --target node && tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc",
    "prepare": "effect-language-service patch",
    "docs": "bunx typedoc src/gatehouse.ts",
    "deploy": "bunx @just-be/deploy"
  },
  "devDependencies": {
    "@effect/language-service": "^0.83.1",
    "@types/bun": "latest",
    "effect-solutions": "^0.5.2",
    "typedoc": "^0.28.18",
    "typescript": "^5"
  },
  "dependencies": {
    "effect": "^4.0.0-beta.40"
  }
}
